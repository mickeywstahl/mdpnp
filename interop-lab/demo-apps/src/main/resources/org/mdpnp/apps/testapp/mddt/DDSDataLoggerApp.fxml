<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.mdpnp.apps.testapp.mddt.DDSDataLoggerApp">

    <top>
        <VBox spacing="6" style="-fx-padding: 10;">
            <Label text="MDDT DDS Data Logger" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Status:"/>
                <Label fx:id="statusLabel" text="Idle" style="-fx-font-style: italic;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Log file:"/>
                <Label fx:id="logFileLabel" text="(not started)" style="-fx-font-style: italic;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Events logged:"/>
                <Label fx:id="eventCountLabel" text="0"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 10;">

            <!-- Device filter -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Device UDI filter (blank = all):"/>
                <TextField fx:id="deviceFilterField" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <!-- Buttons -->
            <HBox spacing="10">
                <Button fx:id="startLoggingButton" text="Start Logging"
                        onAction="#startLogging" style="-fx-base: #4CAF50;"/>
                <Button fx:id="stopLoggingButton"  text="Stop Logging"
                        onAction="#stopLogging"  style="-fx-base: #f44336;" disable="true"/>
                <Button fx:id="flushButton"        text="Flush to Disk"
                        onAction="#flushLog"/>
            </HBox>

            <!-- Live event stream -->
            <Label text="Live event stream:" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="eventDisplay" editable="false" wrapText="true"
                      VBox.vgrow="ALWAYS" prefHeight="400"/>
        </VBox>
    </center>

</BorderPane>
